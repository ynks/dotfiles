# MONITORS
monitor=,preferred,auto,1.5

# VARIABLES
$terminal = wezterm
$fileManager = dolphin
$menu = wofi --show drun

# AUTOSTART
exec-once = waybar & hyprpaper

# env
env = XCURSOR_SIZE,24
env = HYPRCURSOR_SIZE,24

# LOOK AND FEEL
source = ./behaviour.conf

# INPUT
source = ./input.conf

# KEYBINDINGS
source = ./binds.conf

# WINDOWS AND WORKSPACES
source = ./rules.conf

